# Required environment variables for the production stack.
# Copy this file to .env on the deployment host and fill in real values.
# Never commit .env to git.

# Database configuration
DATABASE_NAME=wc26
DATABASE_USER=wc26_user
DATABASE_PASSWORD=<generate with: openssl rand -base64 32 | tr -d '/+=' | head -c 32>

# JWT signing
# Generate with: openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=<generate a long random string, 64+ bytes base64-encoded>
JWT_ISSUER=wc26-backend
JWT_AUDIENCE=wc26-clients

# Firebase Cloud Messaging config
FIREBASE_KEY_PATH=/app/secrets/service-account-key.json