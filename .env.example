# ─────────────────────────────────────────────────────
# WC26 Backend — Local Environment Variables
# ─────────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values.
#   cp .env.example .env
#
# .env is git-ignored and will never be committed.
# ─────────────────────────────────────────────────────

# SMTP — Password Reset Emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-noreply@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_ADDRESS=your-noreply@gmail.com
SMTP_FROM_NAME=WC26
SMTP_START_TLS=true
